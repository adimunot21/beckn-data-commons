{
  "name": "beckn-data-commons",
  "version": "0.0.0",
  "private": true,
  "description": "A Beckn-native, consent-governed dataset & model exchange, accessible to AI agents via MCP.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@types/node": "22.10.5",
    "eslint": "9.17.0",
    "prettier": "3.4.2",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.19.1",
    "vitest": "2.1.8"
  }
}
