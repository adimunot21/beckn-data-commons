# Production environment for Beckn Data Commons.
#
# Copy to infra/.env.prod (which is gitignored) and fill in. Most values are
# GENERATED, not typed — see the commands below. NEVER commit the real file.
#
# Run the stack with:
#   docker compose --env-file infra/.env.prod -f infra/docker-compose.prod.yml up -d

# ---- Public hostname ----
# The name clients (and Caddy's TLS) will use. Options (see docs/DEPLOY.md):
#   - a domain you point at the server:      bdc.example.com
#   - a FREE cert-able name from the server IP (no domain needed):  203.0.113.10.sslip.io
PUBLIC_HOST=REPLACE_ME.sslip.io

# ---- Database ----
POSTGRES_USER=bdc
POSTGRES_DB=bdc
# Use a long random value, e.g.  openssl rand -hex 24
POSTGRES_PASSWORD=REPLACE_WITH_A_STRONG_RANDOM_SECRET

# ---- Access Manager grant-signing keypair ----
# Generate:  pnpm --filter @bdc/access-manager gen-keys
# then paste both emitted values here.
AM_PRIVATE_KEY=
ACCESS_MANAGER_PUBLIC_KEY=

# ---- Per-hop Beckn message-auth keys + shared registry ----
# Generate all at once:  node infra/gen-beckn-keys.mjs
# then paste the emitted lines here (four private keys + the registry).
BAP_BECKN_PRIVATE_KEY=
BPP_TABULAR_BECKN_PRIVATE_KEY=
BPP_VISION_BECKN_PRIVATE_KEY=
BPP_MODELS_BECKN_PRIVATE_KEY=
BECKN_REGISTRY=

# ---- Optional ----
# Requests per minute per IP (default 600).
# RATE_LIMIT_MAX=600
