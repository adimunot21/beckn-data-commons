  "dependencies": {
    "@bdc/beckn-schemas": "workspace:*",
    "@bdc/crypto-utils": "workspace:*",
    "fastify": "5.2.0",
    "pg": "8.13.1"
  },
  "devDependencies": {
    "@types/pg": "8.11.10"
  }
}
