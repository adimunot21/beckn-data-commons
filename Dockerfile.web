# syntax=docker/dockerfile:1
#
# The web app (apps/web, Next.js standalone). Separate from the parameterized
# service Dockerfile because the build/runtime shape differs: Next traces its own
# minimal node_modules into .next/standalone, so the runtime image carries the
# pruned bundle instead of the whole workspace. Repo root is the build context
# (the docs/ and course/ markdown is read at build time for the static pages).

FROM node:22-slim AS build
RUN corepack enable
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
# Build the web app's workspace deps, then the app itself.
RUN pnpm --filter "@bdc/web..." build

FROM node:22-slim AS runtime
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
WORKDIR /app
# Monorepo standalone output nests under apps/web inside the bundle.
COPY --from=build /app/apps/web/.next/standalone ./
COPY --from=build /app/apps/web/.next/static ./apps/web/.next/static
EXPOSE 3000
CMD ["node", "apps/web/server.js"]
