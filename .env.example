# Copy to .env and adjust as needed:  cp .env.example .env
# Never commit .env — it is gitignored.

# ---- Service ports (host-side) ----
BAP_PORT=3001
BPP_TABULAR_PORT=3002
BPP_IMAGE_PORT=3012
BPP_MODELS_PORT=3022
ACCESS_MANAGER_PORT=3003
# (the MCP server is host-run stdio, not a backend port — see docs/mcp-setup.md)

# ---- Postgres ----
POSTGRES_USER=bdc
POSTGRES_PASSWORD=bdc_dev_password
POSTGRES_DB=bdc
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- Access Manager keys ----
# Generate a dev keypair:  pnpm --filter @bdc/access-manager gen-keys
# Then export both before `docker compose up` (never commit real keys):
#   AM_PRIVATE_KEY           -> signs grants (Access Manager only)
#   ACCESS_MANAGER_PUBLIC_KEY -> verifies grants (all BPPs)
AM_PRIVATE_KEY=
ACCESS_MANAGER_PUBLIC_KEY=

# ---- Beckn (populated in Phase 1 after Fabric sandbox registration) ----
# BAP_ID=
# BAP_URI=
# BPP_ID=
# BPP_URI=
# REGISTRY_URL=https://fabric.nfh.global
